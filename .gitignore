# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Documentation (except README.md)
docs/
*.md
!README.md

# GitHub folder
.github/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ===================
# ML Training (ml/)
# ===================

# Training data (large files)
ml/data/
ml/*.csv

# Model checkpoints and weights
ml/models/
ml/*.pth
ml/*.pt
ml/*.onnx
ml/*.pb
ml/*.h5
ml/*.keras
ml/*.weights
ml/*.safetensors

# Keep exports placeholder
!ml/exports/.gitkeep

# Allow production model in public/
!public/mood_detector.onnx
!public/mood_detector.json

# AI/ML Training artifacts
ml/checkpoints/
ml/experiments/
ml/results/
ml/outputs/
wandb/
.wandb/
mlruns/
.neptune/
lightning_logs/

# Model export and optimization
ml/*.tflite
ml/*.torchscript
ml/*.blade
*.tflite
*.torchscript

# Python
__pycache__/
*.pyc
*.pyo
.Python
ml/venv/
ml/env/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# Jupyter and AI notebooks
.ipynb_checkpoints/
*.ipynb
.ipynb_*
nbs/

# Kaggle cache
.kaggle/
kagglehub/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs and monitoring
*.log
ml/tensorboard/
ml/runs/
tb_logs/
train_logs/
*.tfevents.*

# ===================
# Documentation
# ===================

# Temporary development notes only
*.draft.md
*.temp.md
.ai/
.cursor/

# Keep important docs
# docs/ folder is tracked
# README.md is tracked
# LICENSE is tracked
